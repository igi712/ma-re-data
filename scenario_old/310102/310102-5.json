{"story":{"group_1":[{"bg":"bg_adv_21025.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"mouthOpen":1,"pos":2}],"nameLeft":"ももこ","textRight":"ももこ～@ま～た、お弁当真っ茶色じゃ～ん","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":100}],"textLeft":"しょーがないだろぉ～？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001}],"textLeft":"育ちざかりの兄貴と弟の分と@一緒に作ったら…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":1}],"textLeft":"茶色１色に@ならざるを得ないんだっつの"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200}],"textRight":"嘘つけ@学食でもカツ丼食べてるくせに"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101001,"motion":300,"mouthOpen":1}],"textLeft":"バレたかっ…！"},{"chara":[{"effect":"fadeout","id":101001},{"effect":"fadeout","id":800200}],"nameNarration":"ももこ","narration":"兄貴と弟…@男兄弟に挟まれて育ったせいか@すこぶる男っぽい女子に育ってしまった","narrationBg":"bg_adv_21025.jpg","narrationEffect":"in"},{"narration":"でも…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":0}],"nameLeft":"","narrationEffect":"out","textLeft":"えー！超カワイイっ！@[chara:200101:cheek_1:face_mtn_ex_011.exp.json]ねぇ、ももこっ…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":1,"pos":2,"soulGem":0}],"nameRight":"ももこ","textRight":"ん～？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800300,"mouthOpen":1,"pos":0}],"textLeft":"いやいや！ももこは、こんな@ラブリーなの興味ないってぇ"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":0}],"textLeft":"あは、確かに"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":0}],"textRight":"うえ～っ@ンだよぉ"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101001,"motion":200}],"textRight":"ほらほら、@アタシにも見せてみなぁ～っ？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800100,"mouthOpen":1}],"textLeft":"あっはは、やだぁ～っ"},{"bg":"bg_adv_21021.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"lipSynch":0,"motion":1,"pos":1,"soulGem":0}],"nameCenter":"ももこ","textCenter":"（新しく出たばっかの@キャラクター…ね…）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"lipSynch":0}],"textCenter":"（おとぼけキャラの@たれ耳ウサギ…か…）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"lipSynch":0,"motion":100}],"textCenter":"（確かに@アタシには可愛すぎる…）"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101001,"lipSynch":0}],"textCenter":"（でも…）"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101001,"lipSynch":0,"motion":1}],"textCenter":"（実はもう、@マスコット手に入れて…）"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101001,"lipSynch":0,"motion":300}],"textCenter":"（カバンに付けちゃってたり@するんだな、これが…）"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101001,"lipSynch":0,"motion":1}],"textCenter":"（…ま、@内ポケットのチャックだけど…）"},{"chara":[{"effect":"fadeout","id":101001}],"nameNarration":"ももこ","narration":"でもアタシだって一応女子なんだよ","narrationBg":"bg_adv_21021.jpg","narrationEffect":"in"},{"narration":"人並に…@…いや@ひょっとしたら人並以上に@可愛いものとか好きなんだ"},{"narration":"似合わないってことは@よーく自覚してるから…@お気に入りのぬいぐるみだって@布団の下に隠してあるけど…"},{"bg":"bg_adv_21025.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500,"motion":0,"pos":2}],"nameLeft":"ももこ","nameRight":"","narrationEffect":"out","textRight":"十咎！@最新刊！読むだろっ？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":0}],"textLeft":"マジでっ？@貸してくれんのっ？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"pos":2}],"nameLeft":"ももこ","textRight":"ももこっ！@今日の放課後空いてるっ？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001}],"textLeft":"おー、どしたー？"},{"chara":[{"effect":"fadeout","id":101001},{"effect":"fadeout","id":800200}],"nameNarration":"ももこ","narration":"自分の男っぽい性格…@決して嫌いじゃぁない","narrationBg":"bg_adv_21021.jpg","narrationEffect":"in"},{"narration":"変に意識しなくていいからって@男子も自然体で接してくれるし…"},{"narration":"女子だって…@恋愛に関するいざこざとは無縁なもんだから@妙に構えることなく慕ってくれる"},{"narration":"でも…"},{"bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"ももこ","narrationEffect":"out","textLeft":"…ん！あった！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800400,"motion":0,"pos":2}],"textRight":"十咎じゃん@どしたの？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001}],"textLeft":"――っ!!@[chara:101001:cheek_1]えっ…"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101001}],"textLeft":"…あ～っ@これこれっ…！"},{"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":101001,"motion":1}],"textLeft":"テキスト一式…職員室に持って@こいって言われちゃってさ～"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800400}],"textRight":"えぇ？先生も女子に@そんな重労働、頼むなよなぁ"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101001,"lipSynch":0}],"textLeft":"（――っ!!@“女子”…か…）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800400}],"textRight":"手伝うよ"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101001}],"textLeft":"へっ!?@[chara:101001:motion_000]えあっ…！[chara:101001:cheek_2]"},{"nameCenter":"","textCenter":"あー！@いいとこ、いたー！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"lipSynch":0}],"textLeft":"？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":2}],"textRight":"ねー、これ運ぶの手伝って～？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101001}],"textLeft":"――っ!!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800400,"motion":0,"pos":2}],"textRight":"へ？@あ、でも…"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101001,"motion":100}],"textLeft":"いいよ！@そっち手伝ってあげな！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101001,"motion":200}],"textLeft":"アタシの腕っ節の強さ、@[chara:101001:cheek_1:face_mtn_ex_011.exp.json]知ってんだろぉ？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101001,"motion":1}],"textLeft":"かよわい女子の@フォローは頼んだ！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800400}],"textRight":"ん、分かった"},{"chara":[{"effect":"fadeout","id":800400}],"textRight":"…せぇ～のっ…！@…ふふっ…やだぁ～っ…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"lipSynch":0,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101001,"lipSynch":0,"motion":300}],"textLeft":"（可愛く『手伝って』なんて…@言えないよな…）"},{"chara":[{"effect":"fadeout","id":101001}],"nameNarration":"ももこ","narration":"こと恋愛においては…@何度、自分の男らしさを恨んだことか@言い訳がましいのは好きじゃないが…","narrationBg":"bg_adv_21131.jpg","narrationEffect":"in"},{"narration":"華奢で可愛らしくて@見るからに女の子って感じで…"},{"narration":"アタシもそんな…@もっと女の子らしい子だったら…"},{"narration":"重たい物運ぶの手伝ってもらったり…@怪我したときには負ぶってもらったり…"},{"narration":"あんなときも、そんなときも…@もっと積極的になれるんじゃないか@距離を縮められるんじゃないかって…"},{"bg":"bg_adv_21131.jpg","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101001,"lipSynch":0,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"ももこ","narrationEffect":"out","textCenter":"（もっと違う自分だったらな…）"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":2}