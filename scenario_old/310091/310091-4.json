n_ex_050.exp.json","id":101001}],"textRight":"え…？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101101,"lipSynch":0,"motion":300,"pos":2}],"nameRight":"かえで","textRight":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":300}],"textLeft":"その子入れるとか…@レナは絶対嫌…！"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":101001,"motion":0,"pos":2}],"nameRight":"ももこ","textRight":"…何で？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":0,"mouthOpen":1}],"textLeft":"――っ!!@何で、って…!!"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":300}],"textLeft":"…とろいから@その子…"},{"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101101,"motion":0,"pos":2}],"nameRight":"かえで","textRight":"――っ!!"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":400}],"textLeft":"足、引っ張られそうだから@嫌だって言ってんの！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":1}],"textLeft":"こないだだって、ひとりじゃ@どうしようも出来なくて"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901}],"textLeft":"困ってたんでしょ？"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100901}],"textLeft":"そんな子入れたって、@戦力増えるどころか"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100901,"motion":200}],"textLeft":"面倒見させられるだけじゃない"},{"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101101,"motion":300,"mouthOpen":1}],"textRight":"私…@ごめんなさ…"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100901,"motion":1}],"textLeft":"何でレナたちがっ…"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":101001,"motion":0,"pos":2}],"nameRight":"ももこ","textRight":"やめな"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":0}],"textLeft":"っ…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":1}],"textRight":"…どした？@レナらしくないぞ？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001}],"textRight":"そんな…人が傷付くような@こと言うなんてさ"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100901}],"textLeft":"――っ