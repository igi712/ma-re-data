{"story":{"group_1":[{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_18042.jpg","bgm":"bgm03_story06","chara":[{"id":300300,"motion":400}],"nameLeft":"都 ひなの","nameRight":"鶴乃","textLeft":"今度こそ@全部逃げたみたいだな…","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300}],"textLeft":"助かったぞ、ありがとな"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100300,"motion":101}],"textRight":"ううん、どういたしまして！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":0}],"textLeft":"それでオマエら、@コイツらと何かあったのか？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300,"motion":100}],"textRight":"ほ？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300}],"textLeft":"前にコイツらに@勧誘されたことがあってな"},{"chara":[{"id":300300,"motion":200}],"textLeft":"その時、ブチブチと@オマエらを批判してたからな"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100300,"motion":300}],"textRight":"え、ええと…それはね…"},{"chara":[{"id":100300,"lipSynch":0}],"textRight":"（下手なこと言っちゃうと、@勘違いされちゃうしなー…）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100300,"lipSynch":0}],"textRight":"（ここはとりあえず！）"},{"chara":[{"id":100300,"motion":200}],"textRight":"あの、説明すると長くなるから@とりあえず信用してよ！","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100300,"motion":0}],"textRight":"っていうのじゃ、だめカナ？"},{"chara":[{"id":300300,"motion":300}],"textLeft":"言っておくが、別に@敵視してるわけじゃないぞ？"},{"chara":[{"id":300300}],"textLeft":"むしろ心配してるぐらいだ"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300,"motion":400}],"textLeft":"そもそも、こんなクスリで@自我を失ったような奴らの言葉を"},{"chara":[{"id":300300}],"textLeft":"信用するつもりはないからな"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300,"motion":100}],"textRight":"ほっ？"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100300,"lipSynch":0}],"textRight":"（クスリ…？普通じゃない…？）","tu