031.exp.json","id":101101,"motion":400}],"textRight":"あの…あっ…"},{"chara":[{"id":101101,"lipSynch":0}],"textRight":"（こ、これを伝えようとしたら@い、言わなきゃいけないんだ…）","turnEffect":"thinking"},{"chara":[{"eyeClose":1,"id":101101,"lipSynch":0}],"textRight":"（魔女になっちゃうこととか…）"},{"chara":[{"id":301101,"motion":1}],"textLeft":"かえでちゃん…？","turnEffect":"stop"},{"chara":[{"eyeClose":0,"id":101101,"lipSynch":0}],"textRight":"（ど、どうしよ…）","turnEffect":"thinking"},{"chara":[{"id":101101,"motion":200}],"textRight":"え、えと、とりあえず@解放はいいことなんだけどね","turnEffect":"stop"},{"chara":[{"id":101101}],"textRight":"やり方がだめで…"},{"chara":[{"id":101101,"motion":100}],"textRight":"神浜の[textBlue:うわさ]を作ったり、@魔女を育てたりしててねっ"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"motion":400}],"textLeft":"魔女を育て…!?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001,"motion":0,"pos":0}],"nameLeft":"春名 このみ","textLeft":"噂っていうのは、@噂話を広げるっていうこと？"},{"chara":[{"id":101101,"motion":300}],"textRight":"あぅあぅ…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":200}],"textRight":"と、ととと、とりあえず@調整屋に行って！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101101}],"textRight":"私だと上手く説明できないけど"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101101,"motion":100}],"textRight":"あそこに行けば@ちゃんと説明してもらえるから！"},{"chara":[{"id":303001,"motion":400}],"textLeft":"う、うん！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303001}],"textLeft":"分かったけど、@かえでちゃんはどうするの？"},{"chara":[{"id":101101,"motion":0}],"textRight":"私は他の魔法少女を"},{"autoTurnLast":1.0,"bg":"bg_adv_11042.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101101,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_023.exp.json","id":715001,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":715001,"motion":200,"mouthOpen":1}],"nameRight":"黒羽根","textBg":"shout","textRight":"[flashEffect:flashWhite2][bgEffect:shakeLarge][surround:715000A02]…ヴァアアッ！","turnChangeOut":"fadeOut"},{"autoTurnLast":1.5,"bg":"bg_adv_2107