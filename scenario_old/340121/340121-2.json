{"story":{"group_1":[{"bg":"bg_adv_13021.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401200,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":0,"pos":2}],"nameLeft":"御崎 海香","nameRight":"夏目 かこ","textLeft":"もしかして…あなたも!?","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101}],"textRight":"そうです！"},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_010.exp.json","id":301100,"motion":400,"pos":2}],"se":"7205_magic_girl","textRight":"夏目かこっていいます！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401200,"motion":0}],"textLeft":"神浜市の…魔法少女…！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301100,"motion":1}],"textRight":"はい！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301100}],"textRight":"…え？神浜市の…って@もしかして…"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401200,"motion":1}],"textLeft":"…私はあすなろ市から来たの"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301100,"motion":400}],"textRight":"すごい！あすなろ市の@魔法少女の方は初めてです！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301100,"motion":0}],"textRight":"どうしてこちらに@来られたんですか？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401200,"motion":300}],"textLeft":"…それは…@…その…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301100,"motion":300}],"textRight":"…あ、すいません"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301100}],"textRight":"…何か言いにくいことだったら@大丈夫です…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401200,"motion":0,"pos":0}],"textLeft":"いや、そうじゃなくて…"},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_001.exp.json","id":401201,"motion":1,"pos":0}],"se":"7205_magic_girl","textLeft":"…変身、解きましょうか…"},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_050.exp.json","id":301101,"motion":0,"pos":2}],"se":"7205_magic_girl","textRight":"…あ！そ、そうですね！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":0}],"textLeft":"…で…お答えすると…"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201}],"textLeft":"私…いえ、私たちは魔女を@追いかけて神浜まで来ました"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"motion":400}],"textRight":"魔女を…！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401201,"motion":300}],"textLeft":"一緒に来た友だちとは魔女の@結界ではぐれてしまったようで…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401201}],"textLeft":"きっと@近くにはいると思うのだけど…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101,"motion":1}],"textRight":"それは…@色々と大変ですね…"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":0}],"textLeft":"ただ、かずみは…その仲間は@絶対に無事でいてくれるはずです"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201}],"textLeft":"私たちにはわかるんです"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101,"motion":300}],"textRight":"そうだったんですね…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101}],"textRight":"でも、どこにいるのかも@わからないのに信じてるって…"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301101,"motion":1}],"textRight":"私、素晴らしいことだって@思います！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301101,"motion":100}],"textRight":"心と心で結びついているんですね@素敵だなぁ…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401201,"motion":300}],"textLeft":"…とはいえ…@…どこにいるのか…"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"lipSynch":0,"motion":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301101,"motion":400}],"textRight":"私、お手伝いします！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401201,"motion":0}],"textLeft":"え？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101,"motion":0}],"textRight":"不慣れな場所で@お困りかと思いますし…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101}],"textRight":"それに、こうして魔法少女同士が@会ったのも縁だと思うんです！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"lipSynch":0,"motion":1}],"textLeft":"（…この子の言う通り…確かに@神浜は土地勘のない場所…）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"lipSynch":0}],"textLeft":"（…ひとりで探すよりも@ここは頼らせてもらうか…）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401201,"motion":300}],"textLeft":"…すいません@お言葉に甘えます","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":100}],"textLeft":"手助けをお願いします…！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":400}],"textRight":"はい！@もちろんです！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101}],"textRight":"…じゃあ、早速…！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":200}],"textLeft":"その前に！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"motion":200}],"textRight":"あ、はい！@…何ですか？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":1}],"textLeft":"神浜のことを少し@聞かせてもらえませんか？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201}],"textLeft":"私も探す上で、ここの情報を頭に@入れておきたいので"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301101,"motion":100}],"textRight":"そうですね…！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":400}],"textRight":"…じゃあ、この近くに@私の家があるので、そこで！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401201,"motion":300}],"textLeft":"家？@いや、いきなりご迷惑では…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":0}],"textRight":"お気遣いなく！@家と言ってもお店でもあるので"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":0}],"textLeft":"…お店…？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":1}],"textRight":"はい、古書店です！@「夏目書房」っていうんです！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":1}],"textLeft":"夏目書房…"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}